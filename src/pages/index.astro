    <section class="px-6 py-20 border-t border-green-900/60">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <p class="text-xs font-black uppercase tracking-widest text-lime-500">★ Precio verificado · Mejor valoradas</p>
        </div>
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tighter mb-2 leading-tight">
          El <span class="text-lime-500">top 3</span> de la base de datos
