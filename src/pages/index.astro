          <div class="group bg-[#0a1f0f] border border-zinc-800 hover:border-lime-500/60 transition-all duration-200 p-7 flex flex-col gap-5 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(132,204,22,0.10)]">
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full border-2 border-lime-500 flex items-center justify-center text-lime-500 font-black text-sm shrink-0">3</div>
              <span class="w-12 h-12 flex items-center justify-center bg-lime-500/10 border border-lime-500/30 text-2xl shrink-0">💸</span>
              <span class="text-5xl font-black text-lime-500/30 leading-none select-none">03</span>
