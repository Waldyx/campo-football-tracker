---
import Base from "../layouts/Base.astro";
import { botas } from "../data/botas";
import { findMejorPrecio, scoreDisplay } from "../lib/scoring";

const slugsDestacadas = ["nike-mercurial-superfly-10-elite", "adidas-predator-24-elite", "puma-future-7-ultimate"];
const botasDestacadas = slugsDestacadas
  .map((s) => botas.find((b) => b.slug === s))
  .filter(Boolean) as (typeof botas)[0][];

function scoreGlobal(b: (typeof botas)[0]): number {
  return scoreDisplay(b);
}

const conPrecioLive = botas.filter((b) => findMejorPrecio(b.links_compra) !== undefined);
const sinPrecioLive = botas.filter((b) => findMejorPrecio(b.links_compra) === undefined);

const ranked = [
  ...conPrecioLive.sort((a, b) => scoreGlobal(b) - scoreGlobal(a)),
  ...sinPrecioLive.sort((a, b) => scoreGlobal(b) - scoreGlobal(a)),
];
const top3 = ranked.slice(0, 3);
---

<Base title="CANCHA.BOTAS — Tu bota de fútbol, sin BS">
  <main class="min-h-screen text-white">
    <!-- Franja superior gradient -->
    <div class="h-1.5 bg-gradient-to-r from-lime-500 via-lime-300 to-lime-500"></div>

    <header class="px-6 py-5 border-b border-green-900/60 bg-[#0a1f0f]/80 backdrop-blur-sm sticky top-0 z-50">
