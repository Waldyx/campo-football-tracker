        <p class="text-zinc-400 mb-10 max-w-2xl">
          Las botas con mayor puntuación técnica agregada. Para una recomendación personalizada, usa el quiz.
        </p>

        <div class="grid md:grid-cols-3 gap-6 mb-10">
          {top3.map((b, i) => {
            const mejor = findMejorPrecio(b.links_compra);
            const precio = mejor?.precio_actual ?? b.precio_msrp_eur;
            const score = Math.round(scoreGlobal(b) * 10) / 10;
            return (
              <a
                href={`/bota/${b.slug}`}
