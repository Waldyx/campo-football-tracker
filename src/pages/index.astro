          <circle cx="400" cy="300" r="70" fill="none" stroke="white" stroke-width="2"/>
          <circle cx="400" cy="300" r="4" fill="white"/>
          <rect x="0" y="180" width="120" height="240" fill="none" stroke="white" stroke-width="2"/>
          <rect x="680" y="180" width="120" height="240" fill="none" stroke="white" stroke-width="2"/>
          <rect x="0" y="230" width="50" height="140" fill="none" stroke="white" stroke-width="2"/>
          <rect x="750" y="230" width="50" height="140" fill="none" stroke="white" stroke-width="2"/>
          <circle cx="120" cy="300" r="55" fill="none" stroke="white" stroke-width="1.5"/>
          <circle cx="680" cy="300" r="55" fill="none" stroke="white" stroke-width="1.5"/>
        </svg>
      </div>

      <div class="relative max-w-4xl mx-auto text-center">
        <p class="inline-block px-4 py-1.5 mb-10 text-xs font-black uppercase tracking-widest text-zinc-950 bg-lime-300 -rotate-2 shadow-[3px_3px_0_0_rgb(249,115,22)]">
          ★ BETA · v0.1 EN CONSTRUCCIÓN
        </p>

        <h1 class="text-6xl md:text-8xl font-black tracking-tighter mb-8 leading-[0.85] uppercase">
          Tus botas<br />
          <span class="text-lime-500 italic">perfectas</span><br />
          están aquí
        </h1>

        <p class="text-lg md:text-xl text-zinc-300 mb-12 max-w-2xl mx-auto leading-relaxed">
          Cuéntanos cómo juegas. Te decimos las <span class="text-lime-400 font-black">5 botas</span> que mejor encajan contigo y dónde están al mejor precio. <span class="text-zinc-500 italic">Sin sesgo. Sin BS.</span>
        </p>

        <div class="flex flex-wrap items-center justify-center gap-4">
          <a
