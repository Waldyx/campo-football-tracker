            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full border-2 border-lime-500 flex items-center justify-center text-lime-500 font-black text-sm shrink-0">2</div>
              <span class="w-12 h-12 flex items-center justify-center bg-lime-300/10 border border-lime-300/30 text-2xl shrink-0">⚡</span>
              <span class="text-5xl font-black text-lime-300/30 leading-none select-none">02</span>
