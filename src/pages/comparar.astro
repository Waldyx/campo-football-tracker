---
import Base from "../layouts/Base.astro";
---

<Base
  title="Comparador de botas de fútbol | CAMPO"
  description="Compara hasta 3 botas de fútbol lado a lado. Puntuaciones, precios en tiendas españolas y veredicto honesto."
>
  <main class="min-h-screen text-white">
    <header class="px-6 py-5 border-b border-green-900/60 bg-[#0a1f0f]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-black tracking-tighter">
          CAMPO<span class="text-lime-500">.</span>
        </a>
        <nav class="hidden sm:flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest">
          <a href="/botas" class="hover:text-lime-500 transition-colors">Catálogo</a>
          <a href="/rankings" class="hover:text-lime-500 transition-colors">Rankings</a>
          <a href="/metodologia" class="hover:text-lime-500 transition-colors">Método</a>
          <a href="/faq" class="hover:text-lime-500 transition-colors">FAQ</a>
        </nav>
      </div>
    </header>

    <noscript>
      <div class="px-6 py-20 text-center max-w-2xl mx-auto">
        <p class="text-lime-500 font-black uppercase tracking-widest text-xs mb-4">⚠ JavaScript requerido</p>
        <p class="text-zinc-400 mb-6">El comparador necesita JavaScript para funcionar. Actívalo y recarga.</p>
        <a href="/botas" class="inline-block px-6 py-3 bg-lime-500 text-zinc-950 font-black uppercase tracking-wider">← Ver catálogo</a>
      </div>
    </noscript>

    <!-- Selector -->
    <section id="estado-selector" class="hidden px-6 py-12">
      <div class="max-w-4xl mx-auto">
        <p class="text-xs font-black uppercase tracking-widest text-lime-500 mb-4">★ Comparador</p>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight uppercase mb-3">Elige 2 o 3 botas</h1>
        <p class="text-zinc-400 mb-8">Las verás lado a lado con todas sus métricas, precios y veredictos.</p>

        <div class="relative mb-5">
          <span class="absolute left-4 top-1/2 -translate-y-1/2 text-zinc-500 text-sm select-none">🔍</span>
          <input id="selector-search" type="text" placeholder="Buscar bota…" autocomplete="off"
            class="w-full sm:max-w-sm pl-10 pr-4 py-2.5 bg-zinc-900/80 border border-zinc-700 focus:border-lime-500 rounded-full text-white text-sm font-medium outline-none transition-colors placeholder-zinc-600" />
        </div>

        <div id="selector-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-4"></div>

        <div class="flex justify-center mb-6">
          <button id="btn-limpiar" class="hidden text-xs text-zinc-500 hover:text-lime-400 underline transition-colors">Limpiar selección</button>
        </div>

        <div id="empty-state" class="text-center py-16 text-zinc-600">
          <p class="text-4xl mb-3">⚽</p>
          <p class="font-medium text-zinc-400">Selecciona dos botas para comparar</p>
          <p class="text-sm mt-1">Usa el buscador de arriba para encontrar modelos</p>
        </div>

        <div class="flex items-center justify-between gap-4">
          <p id="selector-count" class="text-sm text-zinc-500">0 seleccionadas</p>
          <button id="selector-comparar" type="button" disabled
            class="px-8 py-4 bg-lime-500 hover:bg-lime-400 text-zinc-950 font-black uppercase tracking-wider transition-all disabled:bg-zinc-800 disabled:text-zinc-600 disabled:cursor-not-allowed shadow-[4px_4px_0_0_rgb(255,255,255)] disabled:shadow-none">
            Comparar →
          </button>
        </div>
      </div>
    </section>

    <!-- Comparativa -->
    <section id="estado-comparativa" class="hidden px-6 py-12">
      <div class="max-w-7xl mx-auto">
        <div class="mb-10">
          <p class="text-xs font-black uppercase tracking-widest text-lime-500 mb-3">★ Comparativa lado a lado</p>
          <h1 class="text-3xl md:text-5xl font-black tracking-tight uppercase mb-3 leading-tight">
            <span id="comp-titulo"></span>
          </h1>
          <p class="text-zinc-400">Mejor valor en cada métrica resaltado en <span class="text-lime-500 font-black">naranja</span>.</p>
        </div>

        <div class="overflow-x-auto -mx-6 px-6 pb-4">
          <div id="comp-tabla" class="grid gap-4 min-w-fit" data-cols="2"></div>
        </div>

        <div class="mt-12 flex flex-wrap gap-4 justify-center">
          <a href="/comparar" class="px-6 py-3 border-2 border-zinc-700 hover:border-lime-500 font-black uppercase tracking-wider text-sm transition-colors">↻ Nueva comparativa</a>
          <a href="/quiz" class="px-6 py-3 text-zinc-500 hover:text-white font-bold uppercase tracking-widest text-xs transition-colors self-center">¿No sabes cuál elegir? Haz el quiz</a>
        </div>
      </div>
    </section>

    <!-- Error -->
    <section id="estado-error" class="hidden px-6 py-20">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-xs font-black uppercase tracking-widest text-lime-500 mb-4">⚠ Botas no encontradas</p>
        <h1 class="text-4xl md:text-5xl font-black tracking-tight uppercase mb-6">Esos IDs no existen.</h1>
        <p class="text-zinc-400 mb-8">Vuelve al selector y elige botas válidas de la lista.</p>
        <a href="/comparar" class="inline-block px-8 py-4 bg-lime-500 hover:bg-lime-400 text-zinc-950 font-black uppercase tracking-wider transition-all shadow-[4px_4px_0_0_rgb(255,255,255)]">← Volver al selector</a>
      </div>
    </section>
  </main>

  <script>
    import { botas, getBotaBySlug } from "../data/botas";
    import { findMejorPrecio } from "../lib/scoring";
    import type { Bota, Puntuaciones } from "../lib/types";

    const LABELS_TIENDA: Record<string, string> = {
      amazon_es: "Amazon", decathlon: "Decathlon", nike_es: "Nike",
      adidas_es: "Adidas", puma_es: "Puma", ua_es: "Under Armour",
      nb_es: "New Balance", mizuno_es: "Mizuno", footlocker_es: "Foot Locker",
      jd_sports_es: "JD Sports", zalando_es: "Zalando", sprinter_es: "Sprinter",
    };

    function escapeHtml(s: string | number): string {
      const div = document.createElement("div");
      div.textContent = String(s);
      return div.innerHTML;
    }

    function renderSelector() {
      const $grid = document.getElementById("selector-grid")!;
      const $count = document.getElementById("selector-count")!;
      const $btn = document.getElementById("selector-comparar") as HTMLButtonElement;
      const $limpiar = document.getElementById("btn-limpiar") as HTMLButtonElement;
      const $emptyState = document.getElementById("empty-state")!;
      const seleccion = new Set<string>();

      $grid.innerHTML = botas.map((b) => `
        <button type="button" data-id="${escapeHtml(b.id)}"
          class="selector-card text-left p-4 border-2 border-zinc-800 bg-zinc-900/50 hover:border-lime-500 transition-all cursor-pointer flex flex-col gap-1">
          <div class="flex items-start justify-between gap-1">
            <span class="selector-marca text-xs font-bold uppercase tracking-widest text-zinc-500">${escapeHtml(b.marca)}</span>
            <span class="text-xs font-black text-lime-500/70 shrink-0">${String(Math.round((Object.values(b.puntuaciones).reduce((a, c) => a + c, 0) / 8) * 10) / 10)}</span>
          </div>
          <span class="selector-nombre font-black uppercase text-base leading-tight">${escapeHtml(b.modelo)}</span>
          <span class="text-xs text-zinc-500 mt-1">${escapeHtml(b.precio_msrp_eur)}€</span>
        </button>
      `).join("");

      function refresh() {
        $count.textContent = `${seleccion.size} seleccionada${seleccion.size === 1 ? "" : "s"} ${seleccion.size > 0 ? "(2-3 necesarias)" : ""}`;
        $btn.disabled = seleccion.size < 2 || seleccion.size > 3;
        $limpiar.classList.toggle("hidden", seleccion.size === 0);
        $emptyState.classList.toggle("hidden", seleccion.size > 0);

        $grid.querySelectorAll(".selector-card").forEach((el) => {
          const id = el.getAttribute("data-id")!;
          el.classList.toggle("border-lime-500", seleccion.has(id));
          el.classList.toggle("bg-lime-500/10", seleccion.has(id));
          el.classList.toggle("border-zinc-800", !seleccion.has(id));
        });
      }

      $grid.querySelectorAll<HTMLButtonElement>(".selector-card").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.id!;
          if (seleccion.has(id)) seleccion.delete(id);
          else if (seleccion.size < 3) seleccion.add(id);
          refresh();
        });
      });

      $btn.addEventListener("click", () => {
        if (seleccion.size < 2) return;
        window.location.href = `/comparar?ids=${Array.from(seleccion).join(",")}`;
      });

      $limpiar.addEventListener("click", () => { seleccion.clear(); refresh(); });

      const $selectorSearch = document.getElementById("selector-search") as HTMLInputElement | null;
      $selectorSearch?.addEventListener("input", () => {
        const q = $selectorSearch.value.trim().toLowerCase();
        $grid.querySelectorAll<HTMLButtonElement>(".selector-card").forEach((btn) => {
          const nombre = (btn.querySelector(".selector-nombre")?.textContent || "").toLowerCase();
          const marca = (btn.querySelector(".selector-marca")?.textContent || "").toLowerCase();
          btn.classList.toggle("hidden", q !== "" && !nombre.includes(q) && !marca.includes(q));
        });
      });

      document.getElementById("estado-selector")!.classList.remove("hidden");
      refresh();
    }

    type Atributo = keyof Puntuaciones;
    const ATRIBUTOS: { key: Atributo; label: string; mayorMejor: boolean }[] = [
      { key: "traccion", label: "Tracción", mayorMejor: true },
      { key: "amortiguacion", label: "Amortiguación", mayorMejor: true },
      { key: "control_balon", label: "Control de balón", mayorMejor: true },
      { key: "soporte_lateral", label: "Soporte lateral", mayorMejor: true },
      { key: "estabilidad", label: "Estabilidad", mayorMejor: true },
      { key: "peso_score", label: "Ligereza", mayorMejor: true },
      { key: "durabilidad", label: "Durabilidad", mayorMejor: true },
      { key: "confort", label: "Confort", mayorMejor: true },
    ];

    function scoreBarColor(score: number, scores: number[]): string {
      const max = Math.max(...scores);
      const min = Math.min(...scores);
      if (max === min) return "#71717a";
      if (score === max) return "#84cc16";
      return "#52525b";
    }

    function scoreCell(valor: number, allValues: number[]): string {
      const color = scoreBarColor(valor, allValues);
      return `
        <div class="text-center">
          <div class="flex items-baseline justify-center gap-0.5">
            <span class="font-bold text-lg leading-none">${valor}</span>
            <span class="text-zinc-500 text-xs">/10</span>
          </div>
          <div class="mt-1.5 h-1.5 rounded-full bg-zinc-800 w-16 mx-auto">
            <div class="h-full rounded-full transition-all" style="width:${valor * 10}%;background-color:${color}"></div>
          </div>
        </div>`;
    }

    function indicesGanadores<T>(valores: T[], mayorMejor: boolean = true): Set<number> {
      const nums = valores.map((v) => (typeof v === "number" ? v : NaN));
      if (nums.some((n) => isNaN(n))) return new Set();
      const best = mayorMejor ? Math.max(...nums) : Math.min(...nums);
      const g = new Set<number>();
      nums.forEach((n, i) => { if (n === best) g.add(i); });
      return g;
    }

    function renderFila(label: string, valores: (string | number)[], opts: { ganadores?: Set<number>; html?: boolean } = {}): string {
      const { ganadores, html } = opts;
      const cells = valores.map((v, i) => {
        const isWinner = ganadores?.has(i);
        return `<div class="px-4 py-3 border-l border-zinc-800 ${isWinner ? "text-lime-500 font-black" : "text-zinc-200"} text-sm">${html ? v : escapeHtml(v)}</div>`;
      }).join("");

      return `
        <div class="grid border-b border-zinc-800" style="grid-template-columns: 160px repeat(${valores.length}, minmax(180px, 1fr));">
          <div class="px-4 py-3 text-xs font-bold uppercase tracking-widest text-zinc-500 bg-zinc-900/50 flex items-center">${escapeHtml(label)}</div>
          ${cells}
        </div>`;
    }

    function renderHeader(bts: Bota[]): string {
      const cells = bts.map((b) => {
        const mejor = findMejorPrecio(b.links_compra);
        const precio = mejor?.precio_actual ?? b.precio_msrp_eur;
        const tienda = mejor ? LABELS_TIENDA[mejor.tienda] || mejor.tienda : "";
        const ctaHref = mejor?.url ?? "#";
        return `
          <div class="border-l border-zinc-800 px-4 py-5 bg-zinc-900/30">
            <a href="/bota/${escapeHtml(b.slug)}">
              <img src="${escapeHtml(b.imagen_principal)}" alt="${escapeHtml(b.marca + " " + b.modelo)}"
                class="w-full aspect-[4/3] object-contain p-3 bg-gradient-to-b from-zinc-800 to-zinc-900 mb-4 hover:opacity-90 transition-opacity"
                loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
            </a>
            <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-1">${escapeHtml(b.marca)}</p>
            <a href="/bota/${escapeHtml(b.slug)}" class="hover:text-lime-500 transition-colors">
              <h2 class="text-xl font-black uppercase leading-tight tracking-tight mb-3">${escapeHtml(b.modelo)}</h2>
            </a>
            <p class="text-2xl font-black text-lime-500 mb-3">${escapeHtml(precio)}€${tienda ? ` <span class="text-xs text-zinc-500 font-normal">en ${escapeHtml(tienda)}</span>` : ""}</p>
            <div class="flex flex-wrap gap-2">
              <a href="${escapeHtml(ctaHref)}" target="_blank" rel="noopener noreferrer sponsored"
                class="inline-block px-4 py-2 bg-lime-500 hover:bg-lime-400 text-zinc-950 font-black uppercase tracking-wider text-xs transition-colors">Ver oferta →</a>
              <a href="/bota/${escapeHtml(b.slug)}"
                class="inline-block px-4 py-2 border-2 border-zinc-700 hover:border-lime-500 font-bold uppercase tracking-wider text-xs transition-colors">Ver ficha →</a>
            </div>
          </div>`;
      }).join("");

      return `
        <div class="grid border border-zinc-800 bg-[#0a1f0f]" style="grid-template-columns: 160px repeat(${bts.length}, minmax(180px, 1fr));">
          <div class="px-4 py-5 bg-zinc-900/50"></div>
          ${cells}
        </div>`;
    }

    function renderComparativa(bts: Bota[]) {
      document.getElementById("estado-comparativa")!.classList.remove("hidden");
      document.getElementById("comp-titulo")!.innerHTML = bts
        .map((b) => `<span class="text-lime-500">${escapeHtml(b.modelo)}</span>`)
        .join(" <span class='text-zinc-500'>vs</span> ");

      const $tabla = document.getElementById("comp-tabla")!;
      $tabla.dataset.cols = String(bts.length);

      let html = "";
      html += renderHeader(bts);

      html += `<div class="text-xs font-black uppercase tracking-widest text-lime-500 mt-6 mb-2">Datos físicos</div>`;
      html += `<div class="border border-zinc-800">`;
      html += renderFila("Año", bts.map((b) => b.año_lanzamiento));
      html += renderFila("Peso (EU 42)", bts.map((b) => `${b.peso_real_g} g`), { ganadores: indicesGanadores(bts.map((b) => b.peso_real_g), false) });
      html += renderFila("Horma", bts.map((b) => b.horma));
      html += renderFila("Superficies", bts.map((b) => b.superficies_compatibles.join(", ")));
      html += renderFila("Categoría", bts.map((b) => b.categoria_principal));
      html += `</div>`;

      html += `<div class="text-xs font-black uppercase tracking-widest text-lime-500 mt-6 mb-2">Puntuaciones (1-10)</div>`;
      html += `<div class="border border-zinc-800">`;
      for (const attr of ATRIBUTOS) {
        const valores = bts.map((b) => b.puntuaciones[attr.key]);
        const ganadores = indicesGanadores(valores, attr.mayorMejor);
        const cells = valores.map((v) => scoreCell(v, valores));
        html += renderFila(attr.label, cells, { ganadores, html: true });
      }
      html += `</div>`;

      html += `<div class="text-xs font-black uppercase tracking-widest text-lime-500 mt-6 mb-2">Veredicto</div>`;
      html += `<div class="border border-zinc-800">`;
      html += renderFila("Resumen", bts.map((b) => `<span class="text-xs leading-relaxed">${escapeHtml(b.resumen)}</span>`), { html: true });
      html += renderFila("Pros", bts.map((b) => `<ul class="text-xs space-y-1">${b.pros.map((p) => `<li class="flex gap-1.5"><span class="text-lime-500">+</span><span>${escapeHtml(p)}</span></li>`).join("")}</ul>`), { html: true });
      html += renderFila("Contras", bts.map((b) => `<ul class="text-xs space-y-1">${b.contras.map((c) => `<li class="flex gap-1.5"><span class="text-zinc-500">−</span><span>${escapeHtml(c)}</span></li>`).join("")}</ul>`), { html: true });
      html += `</div>`;

      $tabla.innerHTML = html;
    }

    const params = new URLSearchParams(window.location.search);
    const idsParam = params.get("ids");

    if (!idsParam) {
      renderSelector();
    } else {
      const ids = idsParam.split(",").map((s) => s.trim()).filter(Boolean).slice(0, 3);
      const encontradas = ids.map((id) => getBotaBySlug(id)).filter((b): b is Bota => b !== undefined);

      if (encontradas.length < 2) {
        document.getElementById("estado-error")!.classList.remove("hidden");
      } else {
        renderComparativa(encontradas);
      }
    }
  </script>
</Base>
