---
import Base from "../../layouts/Base.astro";
import { ARTICLES, ARTICLES_SORTED } from "../../lib/articles";
import { botas } from "../../data/botas";
import { findMejorPrecio, scoreDisplay } from "../../lib/scoring";

export async function getStaticPaths() {
  return ARTICLES.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article: a } = Astro.props;

const relacionadas = a.relatedBotas
  .map((slug) => botas.find((b) => b.slug === slug))
  .filter(Boolean) as (typeof botas)[0][];

const otros = ARTICLES_SORTED.filter((x) => x.slug !== a.slug).slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: new URL("/", Astro.site).toString() },
        { "@type": "ListItem", position: 2, name: "Blog", item: new URL("/blog", Astro.site).toString() },
        { "@type": "ListItem", position: 3, name: a.title, item: new URL(`/blog/${a.slug}`, Astro.site).toString() },
      ],
    },
    {
      "@type": "Article",
      headline: a.title,
      description: a.description,
      datePublished: a.fecha,
      dateModified: a.fecha,
      author: { "@type": "Organization", name: a.author },
      publisher: { "@type": "Organization", name: "CANCHA.BOTAS" },
      mainEntityOfPage: new URL(`/blog/${a.slug}`, Astro.site).toString(),
    },
  ],
};
---

<Base title={a.metaTitle} description={a.description} ogType="article" jsonLd={jsonLd}>
  <main class="min-h-screen text-white">
    <header class="px-6 py-5 border-b border-green-900/60 bg-[#0a1f0f]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-black tracking-tighter">CANCHA<span class="text-lime-500">.</span>BOTAS</a>
        <nav class="hidden sm:flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest">
          <a href="/botas" class="hover:text-lime-500 transition-colors">Catálogo</a>
          <a href="/calculadora" class="hover:text-lime-500 transition-colors">Calculadora</a>
          <a href="/blog" class="text-lime-500" aria-current="page">Blog</a>
          <a href="/faq" class="hover:text-lime-500 transition-colors">FAQ</a>
        </nav>
      </div>
    </header>

    <nav class="px-6 py-4 border-b border-green-900/60 text-xs uppercase tracking-widest text-zinc-600">
      <div class="max-w-3xl mx-auto flex items-center gap-2 flex-wrap">
        <a href="/" class="hover:text-lime-500 transition-colors">Inicio</a>
        <span>/</span>
        <a href="/blog" class="hover:text-lime-500 transition-colors">Blog</a>
        <span>/</span>
        <span class="text-zinc-400">{a.categoria}</span>
      </div>
    </nav>

    <!-- HERO -->
    <section class="px-6 pt-12 pb-8">
      <div class="max-w-3xl mx-auto">
        <p class="text-xs font-black uppercase tracking-widest text-lime-500 mb-4">{a.eyebrow}</p>
        <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-none">{a.heroTitle}</h1>
        <p class="text-zinc-400 mt-4 text-lg">{a.heroSubtitle}</p>
        <div class="flex items-center gap-3 mt-6 text-[10px] font-bold uppercase tracking-widest text-zinc-600">
          <span>{a.fechaLabel}</span><span>·</span>
          <span>{a.readMinutes} min de lectura</span><span>·</span>
          <span>{a.author}</span>
        </div>
      </div>
    </section>

    <!-- CUERPO -->
    <article class="px-6 pb-14">
      <div class="max-w-3xl mx-auto art-body" set:html={a.body} />
    </article>

    <!-- BOTAS MENCIONADAS -->
    {relacionadas.length > 0 && (
      <section class="px-6 py-12 border-t border-green-900/60">
        <div class="max-w-3xl mx-auto">
          <p class="text-xs font-black uppercase tracking-widest text-lime-500 mb-3">★ Del catálogo</p>
          <h2 class="text-2xl font-black uppercase tracking-tighter mb-6">Botas mencionadas</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            {relacionadas.map((b) => {
              const mejor = findMejorPrecio(b.links_compra);
              const precio = mejor?.precio_actual ?? b.precio_msrp_eur;
              return (
                <a href={`/bota/${b.slug}`} class="group bg-[#0a1f0f] border-2 border-zinc-800 hover:border-lime-500 transition-all flex flex-col">
                  <div class="relative">
                    <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`}
                      class="w-full aspect-[4/3] object-contain p-3 bg-gradient-to-b from-zinc-800 to-zinc-900"
                      loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
                    <span class="absolute top-2 right-2 px-2 py-0.5 bg-[#0a1f0f]/90 border border-zinc-700 text-xs font-black text-lime-500">{scoreDisplay(b)}</span>
                  </div>
                  <div class="p-4 flex flex-col flex-1 gap-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">{b.marca}</p>
                    <h3 class="text-base font-black uppercase tracking-tight leading-tight group-hover:text-lime-500 transition-colors">{b.modelo}</h3>
                    <p class="text-lime-500 font-black mt-auto pt-2">desde {Math.round(precio)}€</p>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- CTA QUIZ -->
    <section class="px-6 py-14 border-t border-green-900/60 bg-[#071408]">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tighter mb-3">¿Cuál es tu bota?</h2>
        <p class="text-zinc-400 mb-7 max-w-lg mx-auto">
          Seis preguntas sobre cómo juegas y te decimos las cinco botas que mejor
          encajan contigo. Con el porqué de cada una.
        </p>
        <a href="/quiz" class="inline-block px-9 py-4 bg-lime-500 hover:bg-lime-400 text-zinc-950 font-black uppercase tracking-wider transition-all shadow-[4px_4px_0_0_rgb(255,255,255)]">
          Hacer el quiz →
        </a>
      </div>
    </section>

    <!-- MÁS ARTÍCULOS -->
    {otros.length > 0 && (
      <section class="px-6 py-12 border-t border-green-900/60">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-black uppercase tracking-tighter mb-6">Sigue leyendo</h2>
          <div class="grid sm:grid-cols-3 gap-4">
            {otros.map((o) => (
              <a href={`/blog/${o.slug}`} class="group bg-zinc-900/40 border-2 border-zinc-800 hover:border-lime-500 transition-all p-4 flex flex-col gap-2">
                <span class="text-[10px] font-black uppercase tracking-widest text-lime-500">{o.categoria}</span>
                <h3 class="text-sm font-black uppercase tracking-tight leading-tight group-hover:text-lime-500 transition-colors">{o.title}</h3>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <footer class="px-6 py-10 border-t border-green-900/60 bg-[#071408]">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-500">
        <p>CANCHA<span class="text-lime-500">.</span>BOTAS — Recomendador honesto de botas de fútbol.</p>
        <nav class="flex gap-5 uppercase tracking-widest font-bold">
          <a href="/botas" class="hover:text-lime-500 transition-colors">Catálogo</a>
          <a href="/blog" class="hover:text-lime-500 transition-colors">Blog</a>
          <a href="/metodologia" class="hover:text-lime-500 transition-colors">Método</a>
        </nav>
      </div>
    </footer>
  </main>
</Base>

<style is:global>
  /* Tipografía del cuerpo del artículo (contenido inyectado con set:html) */
  .art-body { color: #d4d4d8; line-height: 1.75; }
  .art-body > * + * { margin-top: 1.15rem; }
  .art-body .art-intro {
    font-size: 1.125rem;
    color: #e4e4e7;
    border-left: 3px solid #84cc16;
    padding-left: 1rem;
  }
  .art-body h2 {
    font-family: 'Barlow Condensed', system-ui, sans-serif;
    font-size: 1.9rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: #fff;
    margin-top: 2.5rem;
  }
  .art-body h3 {
    font-family: 'Barlow Condensed', system-ui, sans-serif;
    font-size: 1.3rem;
    font-weight: 900;
    text-transform: uppercase;
    color: #84cc16;
    margin-top: 1.8rem;
  }
  .art-body strong { color: #fff; font-weight: 700; }
  .art-body a { color: #84cc16; text-decoration: underline; text-underline-offset: 2px; }
  .art-body a:hover { color: #a3e635; }
  .art-body ul, .art-body ol { padding-left: 1.3rem; }
  .art-body ul { list-style: disc; }
  .art-body ol { list-style: decimal; }
  .art-body li + li { margin-top: 0.5rem; }
  .art-body .art-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }
  .art-body .art-table th,
  .art-body .art-table td {
    border: 1px solid #27272a;
    padding: 0.6rem 0.8rem;
    text-align: left;
  }
  .art-body .art-table th {
    background: #18181b;
    color: #84cc16;
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }
</style>
