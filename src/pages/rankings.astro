---
import Base from "../layouts/Base.astro";
import { botas } from "../data/botas";

const topVelocidad = [...botas]
  .sort((a, b) => b.puntuaciones.peso_score - a.puntuaciones.peso_score)
  .slice(0, 8);

const topControl = [...botas]
  .sort((a, b) => b.puntuaciones.control_balon - a.puntuaciones.control_balon)
  .slice(0, 8);

const topDurabilidad = [...botas]
  .sort((a, b) => b.puntuaciones.durabilidad - a.puntuaciones.durabilidad)
  .slice(0, 8);

const topBudget = [...botas]
  .filter((b) => b.precio_msrp_eur <= 100)
  .sort((a, b) => a.precio_msrp_eur - b.precio_msrp_eur)
  .slice(0, 8);
---

<Base
  title="Rankings · Campo"
  description="Los mejores rankings de botas de fútbol: top velocidad, control, durabilidad y las mejores opciones por menos de 100€."
>
  <main class="min-h-screen text-white">
    <header class="px-6 py-5 border-b border-green-900/60 bg-[#0a1f0f]/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <a href="/" class="text-2xl font-black tracking-tighter">
          CAMPO<span class="text-orange-500">.</span>
        </a>
        <nav class="hidden sm:flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest">
          <a href="/botas" class="hover:text-orange-500 transition-colors">Catálogo</a>
          <a href="/metodologia" class="hover:text-orange-500 transition-colors">Método</a>
          <a href="/faq" class="hover:text-orange-500 transition-colors">FAQ</a>
        </nav>
      </div>
    </header>

    <!-- Hero -->
    <section class="px-6 pt-16 pb-10 border-b border-green-900/60">
      <div class="max-w-6xl mx-auto">
        <p class="text-xs font-black uppercase tracking-widest text-orange-500 mb-4">★ Rankings</p>
        <h1 class="text-4xl md:text-6xl font-black tracking-tighter uppercase leading-[0.95] mb-4">
          Las mejores<br />
          <span class="text-orange-500">botas</span><br />
          por categoría
        </h1>
        <p class="text-zinc-400 text-lg max-w-xl leading-relaxed">
          Rankings calculados a partir de puntuaciones objetivas. Sin opinión de marca, sin afiliados que distorsionen el orden.
        </p>
      </div>
    </section>

    <div class="px-6 py-16">
      <div class="max-w-6xl mx-auto space-y-20">

        <!-- 1. Top Velocidad -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">⚡</span>
            <div>
              <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter">
                Top <span class="text-orange-500">velocidad</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">Las más ligeras del mercado. Para extremos y delanteros que viven de la velocidad.</p>
            </div>
          </div>
          <ol class="space-y-3">
            {topVelocidad.map((b, i) => (
              <li class="group">
                <a href={`/bota/${b.slug}`} class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4">
                  <span class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}>{i + 1}</span>
                  <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`} width="48" height="48" class="w-12 h-12 object-contain shrink-0" loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">{b.marca}</p>
                    <p class="font-black tracking-tight truncate">{b.modelo}</p>
                    <p class="text-[10px] text-zinc-600">{b.peso_real_g}g</p>
                  </div>
                  <div class="shrink-0 text-right">
                    <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">{b.puntuaciones.peso_score}/10</span>
                  </div>
                  <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">Ver →</span>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <!-- 2. Top Control -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">🎯</span>
            <div>
              <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter">
                Top <span class="text-orange-500">control de balón</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">Máximo tacto y precisión. Para mediapuntas y jugadores técnicos.</p>
            </div>
          </div>
          <ol class="space-y-3">
            {topControl.map((b, i) => (
              <li class="group">
                <a href={`/bota/${b.slug}`} class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4">
                  <span class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}>{i + 1}</span>
                  <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`} width="48" height="48" class="w-12 h-12 object-contain shrink-0" loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">{b.marca}</p>
                    <p class="font-black tracking-tight truncate">{b.modelo}</p>
                  </div>
                  <div class="shrink-0 text-right">
                    <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">{b.puntuaciones.control_balon}/10</span>
                  </div>
                  <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">Ver →</span>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <!-- 3. Top Durabilidad -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">🪨</span>
            <div>
              <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter">
                Top <span class="text-orange-500">durabilidad</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">Las que más aguantan en superficies duras. Para hierba artificial y turf.</p>
            </div>
          </div>
          <ol class="space-y-3">
            {topDurabilidad.map((b, i) => (
              <li class="group">
                <a href={`/bota/${b.slug}`} class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4">
                  <span class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}>{i + 1}</span>
                  <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`} width="48" height="48" class="w-12 h-12 object-contain shrink-0" loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">{b.marca}</p>
                    <p class="font-black tracking-tight truncate">{b.modelo}</p>
                  </div>
                  <div class="shrink-0 text-right">
                    <span class="inline-block bg-orange-500 text-black text-xs font-black px-2 py-1 tracking-widest">{b.puntuaciones.durabilidad}/10</span>
                  </div>
                  <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">Ver →</span>
                </a>
              </li>
            ))}
          </ol>
        </section>

        <!-- 4. Mejores sub-100€ -->
        <section>
          <div class="flex items-baseline gap-3 mb-8">
            <span class="text-3xl">💰</span>
            <div>
              <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tighter">
                Mejores <span class="text-orange-500">sub-100€</span>
              </h2>
              <p class="text-zinc-500 text-sm mt-1">
                {topBudget.length > 0
                  ? `Las ${topBudget.length} opciones más asequibles del catálogo, ordenadas por precio.`
                  : "De momento no hay botas por debajo de 100€ en el catálogo."}
              </p>
            </div>
          </div>

          {topBudget.length > 0 ? (
            <ol class="space-y-3">
              {topBudget.map((b, i) => (
                <li class="group">
                  <a href={`/bota/${b.slug}`} class="flex items-center gap-4 bg-zinc-900 border border-zinc-800 hover:border-orange-500/50 transition-colors p-4">
                    <span class={`text-2xl font-black tracking-tighter w-8 shrink-0 ${i === 0 ? "text-orange-500" : i === 1 ? "text-zinc-300" : i === 2 ? "text-yellow-600" : "text-zinc-600"}`}>{i + 1}</span>
                    <img src={b.imagen_principal} alt={`${b.marca} ${b.modelo}`} width="48" height="48" class="w-12 h-12 object-contain shrink-0" loading="lazy" onerror="this.onerror=null;this.src='/placeholder-boot.svg'" />
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500">{b.marca}</p>
                      <p class="font-black tracking-tight truncate">{b.modelo}</p>
                    </div>
                    <div class="shrink-0 text-right">
                      <span class="inline-block bg-green-600 text-white text-xs font-black px-2 py-1 tracking-widest">{b.precio_msrp_eur}€</span>
                    </div>
                    <span class="text-zinc-600 group-hover:text-orange-500 transition-colors font-black text-sm shrink-0">Ver →</span>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <div class="bg-zinc-900 border border-zinc-800 p-8 text-center">
              <p class="text-zinc-500 text-sm">El catálogo crece continuamente. Vuelve pronto.</p>
            </div>
          )}
        </section>

      </div>
    </div>

    <footer class="px-6 py-10 bg-[#071408] border-t-4 border-orange-500 mt-16">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-2xl font-black tracking-tighter">CAMPO<span class="text-orange-500">.</span></p>
        <nav class="flex gap-6 text-xs font-bold text-zinc-400 uppercase tracking-widest flex-wrap justify-center">
          <a href="/botas" class="hover:text-orange-500 transition-colors">Catálogo</a>
          <a href="/quiz" class="hover:text-orange-500 transition-colors">Quiz</a>
          <a href="/metodologia" class="hover:text-orange-500 transition-colors">Metodología</a>
          <a href="/faq" class="hover:text-orange-500 transition-colors">FAQ</a>
        </nav>
        <p class="text-xs text-zinc-600 uppercase tracking-widest text-center">Proyecto independiente · Sin sesgo de afiliado</p>
      </div>
    </footer>
  </main>
</Base>
